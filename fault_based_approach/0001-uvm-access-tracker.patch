+++ b/nvidia-uvm/nvidia-uvm-sources.Kbuild
@@ -108,3 +108,5 @@ NVIDIA_UVM_SOURCES += nvidia-uvm/uvm_va_block_test.c
 NVIDIA_UVM_SOURCES += nvidia-uvm/uvm_range_group_tree_test.c
 NVIDIA_UVM_SOURCES += nvidia-uvm/uvm_thread_context_test.c
 NVIDIA_UVM_SOURCES += nvidia-uvm/uvm_rb_tree_test.c
+NVIDIA_UVM_SOURCES += nvidia-uvm/uvm_sampling_tracker.c
+NVIDIA_UVM_SOURCES += nvidia-uvm/uvm_sampling_procfs.c
diff --git a/nvidia-uvm/uvm.c b/nvidia-uvm/uvm.c
index 73ceb70..32ed0f0 100644
--- a/nvidia-uvm/uvm.c
+++ b/nvidia-uvm/uvm.c
@@ -35,7 +35,7 @@
 #include "uvm_linux_ioctl.h"
 #include "uvm_hmm.h"
 #include "uvm_mem.h"
-
+#include "uvm_sampling_tracker.h"
 #define NVIDIA_UVM_DEVICE_NAME          "nvidia-uvm"
 
 static dev_t g_uvm_base_dev;
@@ -1065,6 +1065,9 @@ static int uvm_init(void)
     int ret;
 
     NV_STATUS status = uvm_global_init();
+    
+    uvm_sampling_tracker_init();
+
     if (status != NV_OK) {
         UVM_ERR_PRINT("uvm_global_init() failed: %s\n", nvstatusToString(status));
         ret = -ENODEV;
@@ -1114,6 +1117,8 @@ static void uvm_exit(void)
     uvm_tools_exit();
     uvm_chardev_exit();
 
+    uvm_sampling_tracker_destroy();
+    
     uvm_global_exit();
 
     uvm_test_unload_state_exit();
diff --git a/nvidia-uvm/uvm_forward_decl.h b/nvidia-uvm/uvm_forward_decl.h
index bf8e1fb..4b650d7 100644
--- a/nvidia-uvm/uvm_forward_decl.h
+++ b/nvidia-uvm/uvm_forward_decl.h
@@ -57,6 +57,8 @@ typedef struct uvm_va_block_test_struct uvm_va_block_test_t;
 typedef struct uvm_va_block_wrapper_struct uvm_va_block_wrapper_t;
 typedef struct uvm_va_space_struct uvm_va_space_t;
 typedef struct uvm_va_space_mm_struct uvm_va_space_mm_t;
