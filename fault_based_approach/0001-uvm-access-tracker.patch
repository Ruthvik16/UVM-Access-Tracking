From 115c61af582904d719b5d132c57c22f3ee859cd3 Mon Sep 17 00:00:00 2001
From: nikhilpothuganti <nikhilp23@iitk.ac.in>
Date: Wed, 29 Apr 2026 17:11:21 +0530
Subject: [PATCH] uvm access tracker

---
 nvidia-uvm/nvidia-uvm-sources.Kbuild   |   2 +
 nvidia-uvm/uvm.c                       |   7 +-
 nvidia-uvm/uvm_forward_decl.h          |   2 +
 nvidia-uvm/uvm_gpu_replayable_faults.c |  22 +-
 nvidia-uvm/uvm_sampling_procfs.c       | 505 +++++++++++++++++++++++++
 nvidia-uvm/uvm_sampling_tracker.c      | 235 ++++++++++++
 nvidia-uvm/uvm_sampling_tracker.h      | 122 ++++++
 nvidia-uvm/uvm_va_block.c              |  86 ++++-
 nvidia-uvm/uvm_va_block.h              |  10 +
 nvidia-uvm/uvm_va_range.c              |   5 +
 nvidia-uvm/uvm_va_range.h              |   3 +
 nvidia-uvm/uvm_va_space.c              |   4 +
 nvidia-uvm/uvm_va_space.h              |   3 +
 13 files changed, 997 insertions(+), 9 deletions(-)
 create mode 100644 nvidia-uvm/uvm_sampling_procfs.c
 create mode 100644 nvidia-uvm/uvm_sampling_tracker.c
 create mode 100644 nvidia-uvm/uvm_sampling_tracker.h

