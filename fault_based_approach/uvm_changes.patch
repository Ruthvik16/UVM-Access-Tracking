+// Fully unmap all GPU-accessible pages in a single VA block so that any
+// subsequent GPU access (read or write) triggers a replayable fault.
+// The fault handler reinstalls the PTE pointing to the same physical GPU
+// memory — data does not move.
+//
+// Skips blocks with no GPU read mapping (already unmapped, nothing to do).
+// Caller must hold va_block->lock.
+NV_STATUS uvm_va_block_unmap_for_tracking(uvm_va_block_t *va_block,
+                                           uvm_va_block_context_t *block_context,
+                                           uvm_gpu_id_t gpu_id)
+{
+    uvm_va_block_gpu_state_t *gpu_state;
+    uvm_va_block_region_t region;
+
+    uvm_assert_mutex_locked(&va_block->lock);
+
+    if (!uvm_processor_mask_test(&va_block->mapped, gpu_id))
+        return NV_OK;
+
+    gpu_state = block_gpu_state_get(va_block, gpu_id);
+    if (!gpu_state)
+        return NV_OK;
+
+    // Skip if already fully unmapped (read bit clear means no mapping at all)
+    if (uvm_page_mask_empty(&gpu_state->pte_bits[UVM_PTE_BITS_GPU_READ]))
+        return NV_OK;
+
+    region = uvm_va_block_region_from_block(va_block);
+
+    return uvm_va_block_unmap(va_block,
+                              block_context,
+                              gpu_id,
+                              region,
+                              NULL,
+                              &va_block->tracker);
+}
+
+// Walk every managed VA block in the VA space and fully unmap GPU pages,
+// starting a new tracking epoch. Every subsequent GPU access (read or write)
+// will fault, get recorded by the tracker, and have mappings restored by the
+// fault handler.
+NV_STATUS uvm_tracking_revoke_epoch(uvm_va_space_t *va_space, uvm_gpu_id_t gpu_id)
+{
+    uvm_va_range_t *va_range;
+    uvm_va_block_t *va_block;
+    uvm_va_block_context_t *block_context;
+    NV_STATUS status = NV_OK;
+
+    block_context = uvm_va_block_context_alloc(NULL);
+    if (!block_context)
+        return NV_ERR_NO_MEMORY;
+
+    uvm_va_space_down_read(va_space);
+
+    uvm_for_each_va_range(va_range, va_space) {
+        if (va_range->type != UVM_VA_RANGE_TYPE_MANAGED)
+            continue;
+
+        for_each_va_block_in_va_range(va_range, va_block) {
+            uvm_mutex_lock(&va_block->lock);
+            status = uvm_va_block_unmap_for_tracking(va_block, block_context, gpu_id);
+            uvm_mutex_unlock(&va_block->lock);
+            if (status != NV_OK)
+                goto out;
+        }
+    }
+
+out:
+    uvm_va_space_up_read(va_space);
+    uvm_va_block_context_free(block_context);
+    return status;
+}
